{
  "name": "ace-os",
  "version": "1.0.0",
  "description": "Academic Companion Engine OS - A Linux-based educational operating system for Raspberry Pi",
  "private": true,
  "workspaces": [
    "frontend/desktop-shell",
    "frontend/apps/*",
    "frontend/shared",
    "backend"
  ],
  "scripts": {
    "dev:shell": "npm run dev --workspace=@ace/desktop-shell",
    "dev:backend": "npm run dev --workspace=@ace/backend",
    "dev": "npm-run-all --parallel dev:*",
    "build": "npm-run-all build:shared build:backend build:shell build:apps",
    "build:shared": "npm run build --workspace=@ace/shared",
    "build:backend": "npm run build --workspace=@ace/backend",
    "build:shell": "npm run build --workspace=@ace/desktop-shell",
    "build:apps": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "start:backend": "npm run start --workspace=@ace/backend",
    "preview:shell": "npm run preview --workspace=@ace/desktop-shell"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
